{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": ["nitropush"],
  "ios": {
    "iosModuleName": "NitroPush"
  },
  "android": {
    "androidNamespace": ["nitropush"],
    "androidCxxLibName": "NitroPush"
  },
  "autolinking": {
    "NitroPush": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridNitroPushSdk"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridNitroPushSdk"
      }
    }
  },
  "ignorePaths": ["**/node_modules"]
}
