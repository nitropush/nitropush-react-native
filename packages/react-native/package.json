{
  "name": "@nitropush/react-native",
  "version": "1.0.0-beta.3",
  "description": "NitroPush React Native SDK — Nitro Module exposing the NitroPush spec (impl class HybridNitroPushSdk).",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "react-native": "src/index",
  "source": "src/index",
  "scripts": {
    "build:plugin": "tsc -p tsconfig.plugin.json",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf android/build node_modules/**/android/build lib nitrogen/generated",
    "codegen": "nitrogen --logLevel=\"debug\" && node post-script.js",
    "release": "release-it --preRelease=beta"
  },
  "keywords": [
    "react-native",
    "nitro",
    "nitropush",
    "codepush",
    "ota"
  ],
  "files": [
    "src",
    "react-native.config.js",
    "nitrogen",
    "cpp",
    "nitro.json",
    "android/build.gradle",
    "android/fix-prefab.gradle",
    "android/gradle.properties",
    "android/CMakeLists.txt",
    "android/src",
    "ios/**/*.h",
    "ios/**/*.m",
    "ios/**/*.mm",
    "ios/**/*.cpp",
    "ios/**/*.swift",
    "*.podspec",
    "README.md"
  ],
  "homepage": "https://github.com/nitropush/nitropush-react-native",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nitropush/nitropush-react-native.git"
  },
  "author": "NitroPush",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "tag": "beta"
  },
  "devDependencies": {
    "@types/react": "^19.1.3",
    "nitrogen": "0.35.6",
    "react": "19.2.3",
    "react-native": "0.84.1",
    "react-native-nitro-modules": "0.35.6",
    "release-it": "^17.10.0",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*",
    "react-native-nitro-modules": "*"
  }
}
