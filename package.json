{
  "name": "nitropush-sdk-workspace",
  "private": true,
  "packageManager": "yarn@4.4.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "expo": "yarn workspace @nitropush/expo-example",
    "rn": "yarn workspace @nitropush/react-native-example",
    "sdk": "yarn workspace @nitropush/react-native",
    "release": "yarn workspace @nitropush/react-native release"
  },
  "devDependencies": {
    "turbo": "2.9.9",
    "typescript": "^5.6.3"
  }
}
