{
  "expo": {
    "name": "NitropushExpoExample",
    "slug": "NitropushExpoExample",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "nitropushexpoexample",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.expoexample",
      "supportsTablet": true
    },
    "android": {
      "package": "com.expoexample",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },

      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "@nitropush/react-native",
        {
          "ios": true,
          "android": true
        }
      ],
      [
        "./plugins/with-network-security-config",
        {
          "permissive": true,
          "cleartextHosts": [
            "10.0.2.2",
            "localhost",
            "127.0.0.1",
            "192.168.0.141"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "nitropushServerUrl": "http://localhost:3003",
      "nitropushDeploymentKey": "TEST-KEY-Q1IEQH"
    }
  }
}
