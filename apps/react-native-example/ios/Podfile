# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'NitropushRNExample' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # NitroPush — Xcode 26 strict-modular-headers fix.
    #
    # CocoaPods auto-generates NitroPush-umbrella.h that #imports every
    # public_header_files entry, including the nitrogen-generated C++
    # .hpp files. Xcode 26 validates the umbrella in pure ObjC mode,
    # where the C++ `namespace` keyword fails with
    # "unknown type name 'namespace'".
    #
    # Wrap the .hpp #imports in `#ifdef __cplusplus` so the ObjC pass
    # skips them, while Swift's C++ interop
    # (SWIFT_OBJC_INTEROP_MODE=objcxx, ObjC++ mode) still sees them and
    # resolves margelo::nitro::… types.
    umbrella = File.join(
      installer.sandbox.root.to_s,
      'Target Support Files/NitroPush/NitroPush-umbrella.h'
    )
    if File.exist?(umbrella)
      content = File.read(umbrella)
      hpp_imports = content.scan(/^#import\s+"[^"]+\.hpp"\s*$/).join("\n")
      unless hpp_imports.empty? || content.include?('#ifdef __cplusplus')
        patched = content.sub(
          hpp_imports,
          "#ifdef __cplusplus\n#{hpp_imports}\n#endif"
        )
        File.write(umbrella, patched)
        Pod::UI.puts 'NitroPush umbrella header guarded for Xcode 26'.green
      end
    end
  end
end
